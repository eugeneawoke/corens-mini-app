generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id                String   @id @default(cuid())
  telegramUserId    String   @unique
  telegramUsername  String?
  status            String
  firstSeenAt       DateTime @default(now())
  lastSeenAt        DateTime @updatedAt
  profile           Profile?
}

model Profile {
  userId            String   @id
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName       String
  about             String?
  stateKey          String   @default("calm")
  intentKey         String   @default("slow-dialogue")
  trustKeys         String[] @default([])
  photoCount        Int      @default(0)
  visibilityStatus  String
  matchingEnabled   Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model MatchSession {
  id                String   @id @default(cuid())
  userAId           String
  userBId           String
  origin            String
  status            String
  score             Int?
  createdAt         DateTime @default(now())
  expiresAt         DateTime?
}

model ContactConsent {
  id                String   @id @default(cuid())
  matchSessionId    String
  requestedBy       String
  requestStatus     String
  resolvedAt        DateTime?
}

model PhotoRevealConsent {
  id                String   @id @default(cuid())
  matchSessionId    String
  requestedBy       String
  requestStatus     String
  resolvedAt        DateTime?
}

model BeaconSession {
  id                String   @id @default(cuid())
  userId            String
  status            String
  durationMinutes   Int
  activatedAt       DateTime @default(now())
  expiresAt         DateTime
  cooldownUntil     DateTime?
}

model DeletionEvent {
  id                String   @id @default(cuid())
  userId            String
  stage             String
  requestedAt       DateTime @default(now())
  completedAt       DateTime?
}
