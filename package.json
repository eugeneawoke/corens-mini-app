{
  "name": "corens-mini-app",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "corepack pnpm -r --if-present build",
    "dev": "corepack pnpm -r --parallel --if-present dev",
    "lint": "corepack pnpm -r --if-present lint",
    "prisma:generate": "corepack pnpm --filter @corens/db exec prisma generate",
    "test": "vitest run tests/unit tests/contract tests/integration",
    "test:unit": "vitest run tests/unit",
    "test:contract": "vitest run tests/contract",
    "test:integration": "vitest run tests/integration",
    "typecheck": "corepack pnpm -r --if-present typecheck"
  },
  "prisma": {
    "schema": "packages/db/prisma/schema.prisma"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "prisma": "^6.16.2",
    "tsx": "^4.21.0",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
