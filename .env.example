# Root application identity
NODE_ENV=development
APP_ENV=local
APP_NAME=corens-mini-app
ENABLE_MAINTENANCE_SCHEDULER=false
APP_BASE_URL=http://localhost:3000
API_PORT=4000
BOT_PORT=4100

# Telegram
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_BOT_WEBHOOK_SECRET=replace-me
TELEGRAM_BOT_USERNAME=replace-me
TELEGRAM_MINI_APP_URL=http://localhost:3000

# Database and queues
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/corens
DATABASE_URL_UNPOOLED=postgresql://postgres:postgres@localhost:5432/corens
REDIS_URL=redis://localhost:6379

# Storage
B2_KEY_ID=replace-me
B2_APPLICATION_KEY=replace-me
B2_BUCKET_ID=replace-me
B2_BUCKET_NAME=replace-me
B2_ENDPOINT=
B2_PUBLIC_BASE_URL=

# Analytics and monitoring
POSTHOG_API_KEY=replace-me
POSTHOG_HOST=https://app.posthog.com
SENTRY_DSN=
LOG_LEVEL=debug

# Internal sessions and crypto
SESSION_SECRET=replace-me
TELEGRAM_INIT_DATA_TTL_SECONDS=300

# TODO: split env files per app once runtime wiring is added.
